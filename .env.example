ANTHROPIC_API_KEY=your_anthropic_api_key
AI_MESSAGING_ENABLED=true
AI_MESSAGING_MODEL=claude-haiku-4-5-20251001
AI_MESSAGING_MAX_BATCH=10
NOTION_API_TOKEN=your_notion_token
NOTION_DATABASE_ID=your_notion_database_id
LINKEDIN_CHROME_USER_DATA_DIR=/absolute/path/to/your/signed-in/chrome-data
LINKEDIN_PROFILE_NAME=Default
LINKEDIN_DEBUG_PORT=9222
TIMEZONE=America/Los_Angeles
OUTREACH_ARTIFACTS_DIR=artifacts
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_FROM_EMAIL=you@example.com
SMTP_USERNAME=you@example.com
SMTP_PASSWORD=your_smtp_app_password
SMTP_STARTTLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=30
